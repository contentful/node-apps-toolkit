{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>contentful/renovate-config"],
  "npm": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDepTypes": ["dependencies", "peerDependencies", "optionalDependencies"],
